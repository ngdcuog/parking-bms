{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "parking-api-route": {
        "ClusterId": "parking-api",
        "Match": {
          "Path": "/api/v1/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "parking-api": {
        "Destinations": {
          "parking-api-destination": {
            "Address": "http://localhost:5002"
          }
        }
      }
    }
  }
}
